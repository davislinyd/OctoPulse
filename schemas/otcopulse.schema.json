{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/davislinyd/OctoPulse/schemas/otcopulse.schema.json",
  "title": "OctoPulse v2 Project Pulse",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "name", "last_updated", "phase", "health", "goal", "summary", "next_action", "verification", "attention"],
  "properties": {
    "schema_version": {"const": 2},
    "name": {"type": "string", "maxLength": 160},
    "last_updated": {"type": "string", "format": "date-time"},
    "phase": {"enum": ["planning", "implementation", "verification", "maintenance", "paused"]},
    "health": {"enum": ["active", "stable", "needs_attention", "blocked", "stale"]},
    "goal": {"type": "string", "maxLength": 480},
    "summary": {"type": "string", "maxLength": 1600},
    "next_action": {"type": "string", "maxLength": 480},
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "last_command", "last_verified_at"],
      "properties": {
        "status": {"enum": ["passed", "failed", "not_run", "partial"]},
        "last_command": {"type": "string"},
        "last_verified_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "attention": {"type": "array", "maxItems": 8, "items": {"type": "string"}}
  }
}
